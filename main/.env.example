# 進git，永遠不填值

# Database Configuration
# Copy this file to .env and fill in your actual values

# Database Connection Settings
GCP_HOST=your-gcp-cloud-sql-ip
GCP_PORT=3306
GCP_USER=root
GCP_PASSWORD=your-password
GCP_DB_NAME=skin_perfection_db

# Example for local MySQL:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=mypassword
# DB_NAME=skin_analysis_db

# Example for GCP Cloud SQL (Public IP):
# DB_HOST=34.80.123.456
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-secure-password
# DB_NAME=skin_analysis_db

# Example for GCP Cloud SQL (Private IP with Cloud SQL Proxy):
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your-secure-password
# DB_NAME=skin_analysis_db
